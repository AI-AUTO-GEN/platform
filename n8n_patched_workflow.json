    {
      "parameters": {
        "jsCode": "\nconst task = $json.body.task;\nconst proj = $json.body.project;\n\n// ===== SANITIZADOR DE LEGACY =========\n// Si el shot fue guardado ANTES del parche, todavia tendra la url incorrecta.\n// Lo interceptamos y esterilizamos aqui antes de hacer nada:\nif (task.modelId === 'fal-ai/flux-pro/v1.1/ultra') {\n    task.modelId = 'fal-ai/flux-pro/v1.1-ultra';\n}\n// ======================================\n\nlet payload = { prompt: task.prompt };\nconst m = task.modelId;\n\n// 1. Inyecci\u00c3\u00b3n de Multimedia\nif (task.ref_image) payload.image_url = task.ref_image;\nif (task.ref_video) payload.video_url = task.ref_video;\n\n// 2. CONFIGURACION BASE POR DEFECTO (Si la web no enviara nada)\nif (m.includes('flux')) {\n    payload.output_format = 'jpeg';\n    payload.aspect_ratio = '16:9';\n    if(m.includes('pro')) payload.safety_tolerance = '5';\n}\nif (m.includes('seedance')) {\n    if (m.includes('video')) payload.resolution = '720p';\n    else payload.image_size = 'landscape_16_9';\n}\nif (m.includes('magic-image')) payload.image_size = 'landscape_16_9';\nif (m.includes('kling')) {\n    payload.duration = '5';\n    payload.aspect_ratio = '16:9';\n}\nif (m.includes('hunyuan')) {\n    payload.video_size = 'landscape_16_9';\n    payload.video_length = 129; \n}\nif (m.includes('ltx') || m.includes('minimax')) payload.resolution = '720p';\nif (m.includes('runway')) payload.ratio = '16:9';\nif (m.includes('luma')) payload.aspect_ratio = '16:9';\nif (m.includes('gemini') || m.includes('dalle') || m.includes('gpt') || m.includes('wan') || m.includes('ideogram') || m.includes('recraft')) {\n    if(m.includes('recraft')) payload.size = '1024x576';\n    else if(m.includes('ideogram')) payload.aspect_ratio = '16:9';\n    else payload.image_size = 'landscape_16_9';\n}\n\n// 3. OVERRIDE MAESTRO WEB (El usuario tiene el control supremo)\nif (task.settings && typeof task.settings === 'object') {\n    Object.keys(task.settings).forEach(key => {\n        if(task.settings[key] !== undefined && task.settings[key] !== '') {\n            if(task.settings[key] === 'true') payload[key] = true;\n            else if(task.settings[key] === 'false') payload[key] = false;\n            else if (!isNaN(Number(task.settings[key])) && key !== 'ratio' && key !== 'aspect_ratio' && key !== 'resolution') {\n                payload[key] = Number(task.settings[key]);\n            } else {\n                payload[key] = task.settings[key];\n            }\n        }\n    });\n}\n\nreturn {\n    task_id: task.id,\n    modelId: task.modelId, // Enviamos el modelo sanitizado a n8n\n    kind: task.kind || 't2i',\n    payload: payload,\n    project: proj ? proj.title : 'FREESTYLE',\n    fileName: `${task.id}_${Date.now()}`\n};\n"
      },
