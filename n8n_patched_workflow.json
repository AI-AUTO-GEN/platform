    {
      "parameters": {
        "jsCode": "\nconst src = $input.item.json;\nlet outputUrl = null;\n\n// L\u00c3\u00b3gica de trampa multi-modelo (La Biblia):\nif (src.images && src.images.length > 0) outputUrl = src.images[0].url;\nelse if (src.video && src.video.url) outputUrl = src.video.url;\nelse if (src.url) outputUrl = src.url;\nelse if (src.data && src.data.url) outputUrl = src.data.url;\nelse if (src.file && src.file.url) outputUrl = src.file.url;\nelse if (src.outputs && src.outputs.length > 0 && typeof src.outputs[0] === 'string') outputUrl = src.outputs[0];\n\nif(!outputUrl) {\n   // Dump para debugear\n   throw new Error('Fal.ai response structure unknown: ' + JSON.stringify(src));\n}\n\nconst prev = $node['Format Builder'].json;\n\nreturn {\n    ...prev,\n    generated_url: outputUrl\n};\n"
      },
